# Development defaults
# These values are intentionally local and must never be reused in production.
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=django-insecure-development-only-replace-locally
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_RESET_PASSWORD_URL=http://localhost:3000/reset-password/confirm

# Optional local PostgreSQL. Leave DATABASE_NAME empty to use development SQLite.
DATABASE_NAME=gahambani_development
DATABASE_USER=replace-with-local-user
DATABASE_PASSWORD=replace-with-local-password
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Local email remains in memory and never prints reset tokens to the console.
DJANGO_EMAIL_BACKEND=django.core.mail.backends.locmem.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=GahamBani <no-reply@localhost>
DJANGO_EMAIL_HOST=localhost
DJANGO_EMAIL_PORT=25
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=False
DJANGO_EMAIL_USE_SSL=False

# Optional development cache and throttling overrides.
DJANGO_CACHE_LOCATION=gahambani-development
DRF_THROTTLE_RATE_ANON=100/day
DRF_THROTTLE_RATE_USER=1000/day
DRF_THROTTLE_RATE_LOGIN=5/minute
DRF_THROTTLE_RATE_REGISTRATION=3/hour
DRF_THROTTLE_RATE_PASSWORD_RESET=3/hour
DRF_THROTTLE_RATE_PASSWORD_RESET_CONFIRM=5/hour
DRF_THROTTLE_RATE_TOKEN_REFRESH=20/hour
DRF_NUM_PROXIES=0

# Production required variables
# Supply these through the deployment environment, not by copying local secrets.
# DJANGO_SETTINGS_MODULE=config.settings.production
# DJANGO_SECRET_KEY=replace-with-a-random-secret-of-at-least-50-characters
# DJANGO_ALLOWED_HOSTS=api.example.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://api.example.com,https://app.example.com
# DJANGO_CORS_ALLOWED_ORIGINS=https://app.example.com
# FRONTEND_RESET_PASSWORD_URL=https://app.example.com/reset-password/confirm
# DATABASE_NAME=replace-with-production-database
# DATABASE_USER=replace-with-production-user
# DATABASE_PASSWORD=replace-with-production-password
# DATABASE_HOST=db.example.com
# DATABASE_PORT=5432
# DATABASE_SSLMODE=require
# DATABASE_CONN_MAX_AGE=60
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DJANGO_EMAIL_HOST=smtp.example.com
# DJANGO_EMAIL_PORT=587
# DJANGO_EMAIL_HOST_USER=replace-with-smtp-user
# DJANGO_EMAIL_HOST_PASSWORD=replace-with-smtp-password
# DJANGO_EMAIL_USE_TLS=True
# DJANGO_EMAIL_USE_SSL=False
# DJANGO_DEFAULT_FROM_EMAIL=GahamBani <no-reply@example.com>
# DJANGO_EMAIL_TIMEOUT=10
# DJANGO_TRUST_X_FORWARDED_PROTO=True
# DRF_NUM_PROXIES=replace-with-the-exact-number-of-trusted-proxies
# ALERT_THRESHOLDS_MEDICALLY_VALIDATED=True
# ALERT_BP_VERY_LOW_SYSTOLIC=90
# ALERT_BP_VERY_LOW_DIASTOLIC=60
# ALERT_BP_ELEVATED_SYSTOLIC=140
# ALERT_BP_ELEVATED_DIASTOLIC=90
# ALERT_BP_VERY_HIGH_SYSTOLIC=180
# ALERT_BP_VERY_HIGH_DIASTOLIC=120
# ALERT_BP_CRITICAL_SYSTOLIC=180
# ALERT_BP_CRITICAL_DIASTOLIC=120
# ALERT_HR_LOW=40
# ALERT_HR_HIGH=130
# ALERT_GLUCOSE_VERY_LOW_MG_DL=54
# ALERT_GLUCOSE_HIGH_MG_DL=180
# ALERT_GLUCOSE_VERY_HIGH_MG_DL=250
# ALERT_HBA1C_HIGH_PERCENT=8
# ANALYTICS_MAX_PERIOD_DAYS=365
# ANALYTICS_TREND_WINDOW_DAYS=7
# ANALYTICS_TREND_MIN_MEASUREMENTS=2
# ANALYTICS_TREND_STABLE_THRESHOLD=0.01

# Production optional hardening and cache overrides
# DJANGO_SECURE_HSTS_SECONDS=3600
# DJANGO_CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
# DJANGO_CACHE_LOCATION=gahambani-production
# LocMemCache does not share throttle counters across processes or instances.
